---
import { Icon } from 'astro-icon/components';

interface Props {
  href?: string;
  variant?: 'cta' | 'primary' | 'outline' | 'outline-light' | 'ghost';
  size?: 'md' | 'lg';
  icon?: string;
  iconRight?: string;
  type?: 'button' | 'submit';
  class?: string;
  [key: string]: any;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  icon,
  iconRight,
  type = 'button',
  class: cls = '',
  ...rest
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 font-semibold rounded-md transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-background disabled:opacity-60 disabled:pointer-events-none';

const sizes: Record<string, string> = {
  md: 'text-[0.95rem] px-5 py-2.5',
  lg: 'text-base px-7 py-3.5',
};

const variants: Record<string, string> = {
  cta: 'bg-accent text-primary hover:bg-accent-hover shadow-md hover:-translate-y-px focus-visible:ring-accent',
  primary: 'bg-secondary text-white hover:bg-secondary-hover shadow-sm focus-visible:ring-secondary',
  outline:
    'border-[1.5px] border-primary/20 text-primary hover:border-secondary hover:bg-secondary-soft focus-visible:ring-secondary',
  'outline-light': 'border-[1.5px] border-white/30 text-white hover:bg-white/10 focus-visible:ring-white',
  ghost: 'text-primary hover:bg-primary/5 focus-visible:ring-secondary',
};

const cl = [base, sizes[size], variants[variant], cls].join(' ');
const Tag = href ? 'a' : 'button';
const attrs = href ? { href } : { type };
---

<Tag class={cl} {...attrs} {...rest}>
  {icon && <Icon name={icon} class="text-[1.15em]" />}
  <slot />
  {iconRight && <Icon name={iconRight} class="text-[1.15em]" />}
</Tag>
