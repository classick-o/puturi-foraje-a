---
interface Props {
  eyebrow?: string; // pastrat pentru compatibilitate, nu se mai afiseaza
  title: string;
  subtitle?: string;
  breadcrumb?: { label: string; href?: string }[];
}
const { title, subtitle, breadcrumb = [] } = Astro.props;

// Breadcrumb pastrat DOAR pentru SEO (BreadcrumbList JSON-LD), nu se mai afiseaza in UI.
const crumbLd =
  breadcrumb.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumb.map((b, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: b.label,
          ...(b.href ? { item: new URL(b.href, Astro.site).href } : {}),
        })),
      }
    : null;
---

<section class="border-b border-border bg-surface">
  <div class="wrap py-12 sm:py-16">
    <h1 class="text-3xl sm:text-4xl lg:text-[2.75rem]">{title}</h1>
    {subtitle && <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">{subtitle}</p>}
  </div>
  {crumbLd && <script type="application/ld+json" set:html={JSON.stringify(crumbLd)} />}
</section>
