---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { site, nav } from '../lib/site';
import { withBase } from '../lib/url';
import Button from './Button.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const homeHref = withBase('').replace(/\/+$/, '') || '/';
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => {
  const h = href.replace(/\/+$/, '') || '/';
  if (h === homeHref) return current === homeHref;
  return current === h || current.startsWith(h + '/');
};
const linkBase =
  'rounded-md px-3 py-2 text-[0.95rem] font-medium transition-colors hover:bg-primary/5';
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-border/70 bg-surface/85 backdrop-blur transition-shadow"
>
  <div class="wrap flex h-16 items-center justify-between gap-4 lg:h-[72px]">
    <a href={withBase('')} class="flex items-center gap-2.5" aria-label={site.name}>
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-[10px] bg-primary text-accent">
        <Icon name="ph:drop-duotone" class="text-xl" />
      </span>
      <span class="text-lg font-extrabold tracking-tight text-primary">{site.name}</span>
    </a>

    <nav class="hidden items-center gap-0.5 lg:flex" aria-label="Navigatie principala">
      {
        nav.map((item) =>
          item.label === 'Servicii' ? (
            <div class="group relative">
              <a
                href={item.href}
                class:list={[linkBase, 'flex items-center gap-1', isActive(item.href) ? 'text-primary' : 'text-primary/75']}
              >
                Servicii
                <Icon name="ph:caret-down-bold" class="text-[0.65rem] opacity-60" />
              </a>
              <div class="invisible absolute left-0 top-full w-72 translate-y-1 pt-2 opacity-0 transition-all group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                <div class="rounded-xl border border-border bg-surface p-2 shadow-lg">
                  {services.map((s) => (
                    <a
                      href={withBase(`servicii/${s.id}`)}
                      class="flex items-center gap-2.5 rounded-md px-3 py-2 text-sm text-primary/80 transition-colors hover:bg-secondary-soft hover:text-primary"
                    >
                      <Icon name={s.data.icon} class="text-base text-secondary" />
                      {s.data.title}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class:list={[linkBase, isActive(item.href) ? 'text-primary' : 'text-primary/75']}>
              {item.label}
            </a>
          )
        )
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={site.phoneHref}
        class="hidden items-center gap-2 rounded-md px-3 py-2 text-sm font-semibold text-primary hover:bg-primary/5 xl:flex"
      >
        <Icon name="ph:phone-call-fill" class="text-secondary" />
        {site.phone}
      </a>
      <Button href={withBase('contact')} variant="cta" class="hidden sm:inline-flex">Cere oferta</Button>
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md text-primary hover:bg-primary/5 lg:hidden"
        aria-label="Deschide meniul"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="ph:list-bold" class="text-2xl" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-border bg-surface lg:hidden">
    <nav class="wrap flex flex-col gap-1 py-4" aria-label="Meniu mobil">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="rounded-md px-3 py-2.5 text-base font-medium text-primary/85 hover:bg-secondary-soft"
          >
            {item.label}
          </a>
        ))
      }
      <div class="mt-3 flex flex-col gap-2">
        <Button href={site.phoneHref} variant="outline" icon="ph:phone-call-fill">{site.phone}</Button>
        <Button href={withBase('contact')} variant="cta">Cere oferta gratuita</Button>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('site-header');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
  });

  const onScroll = () => header?.classList.toggle('shadow-md', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
