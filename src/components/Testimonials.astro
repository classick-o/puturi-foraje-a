---
import { Icon } from 'astro-icon/components';
import { testimonials } from '../lib/site';

interface Props {
  limit?: number;
}
const { limit = 3 } = Astro.props;
---

<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
  {
    testimonials.slice(0, limit).map((t) => (
      <figure class="flex flex-col rounded-xl border border-border bg-surface p-6 shadow-sm">
        <div class="flex gap-0.5 text-accent">
          {Array.from({ length: t.rating }).map(() => (
            <Icon name="ph:star-fill" />
          ))}
        </div>
        <blockquote class="mt-3 flex-1 text-[0.95rem] leading-relaxed text-ink/90">
          {t.text}
        </blockquote>
        <figcaption class="mt-5 flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-[10px] bg-secondary-soft font-bold text-secondary">
            {t.name.charAt(0)}
          </span>
          <span>
            <span class="block text-sm font-bold text-primary">{t.name}</span>
            <span class="block text-xs text-muted">{t.city}</span>
          </span>
        </figcaption>
      </figure>
    ))
  }
</div>
