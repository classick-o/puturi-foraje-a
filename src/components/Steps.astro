---
import { steps } from '../lib/site';
---

<ol class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
  {
    steps.map((s, i) => (
      <li class="rounded-xl border border-border bg-surface p-5 shadow-sm">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-[10px] bg-primary text-base font-bold text-accent tabular-nums">
          {i + 1}
        </span>
        <h3 class="mt-3 text-base font-bold text-primary">{s.title}</h3>
        <p class="mt-1.5 text-sm leading-relaxed text-muted">{s.text}</p>
      </li>
    ))
  }
</ol>
