---
import { stats } from '../lib/site';

interface Props {
  variant?: 'light' | 'dark';
  class?: string;
}
const { variant = 'light', class: cls = '' } = Astro.props;
const onDark = variant === 'dark';
---

<div class={`grid grid-cols-2 gap-4 lg:grid-cols-4 ${cls}`}>
  {
    stats.map((s) => (
      <div
        class={`rounded-xl border p-5 text-center ${onDark ? 'border-white/15 bg-white/5' : 'border-border bg-surface shadow-sm'}`}
      >
        <div
          class={`text-3xl font-extrabold tracking-tight tabular-nums ${onDark ? 'text-accent' : 'text-primary'}`}
        >
          {s.value}
        </div>
        <div class={`mt-1 text-sm ${onDark ? 'text-white/70' : 'text-muted'}`}>{s.label}</div>
      </div>
    ))
  }
</div>
