---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import TrustBar from '../components/TrustBar.astro';
import IconTile from '../components/IconTile.astro';
import CtaBand from '../components/CtaBand.astro';
import Button from '../components/Button.astro';
import { Icon } from 'astro-icon/components';
import { site, whyUs } from '../lib/site';
import { withBase } from '../lib/url';

const values = whyUs.slice(0, 6);
const partners = ['Grundfos', 'Wilo', 'Pedrollo', 'DAB', 'Lowara'];
---

<BaseLayout
  title="Despre noi"
  description="Firma de foraje puturi apa cu peste 15 ani de experienta, echipa si utilaje proprii, garantie in scris si pret corect."
>
  <PageHero
    eyebrow="Despre noi"
    title="O echipa serioasa, cu utilaje proprii"
    subtitle="Peste 15 ani de experienta in foraje puturi de apa. Lucram corect, cu materiale de calitate, garantie in scris si documentatie inclusa."
    breadcrumb={[{ label: 'Acasa', href: withBase('') }, { label: 'Despre noi' }]}
  />

  <!-- Poveste -->
  <section class="py-16 sm:py-20">
    <div class="wrap grid items-center gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-3xl sm:text-4xl">Foraje facute ca la carte, de peste 15 ani</h2>
        <div class="mt-4 space-y-4 leading-relaxed text-muted">
          <p>
            Am pornit de la un singur utilaj si o promisiune simpla: lucrari de calitate, la un pret
            corect. Cu timpul am crescut, am investit in echipamente moderne si ne-am format o echipa
            de oameni cu experienta, dar promisiunea a ramas aceeasi.
          </p>
          <p>
            Astazi executam foraje in toata tara, de la puturi pentru gospodarie pana la sonde pentru
            pompe de caldura, si ne ocupam inclusiv de documentatia necesara. Punem accent pe
            transparenta: stii din start la ce sa te astepti, fara costuri ascunse.
          </p>
        </div>
        <div class="mt-8">
          <Button href={withBase('contact')} variant="primary" iconRight="ph:arrow-right-bold">Discuta cu noi</Button>
        </div>
      </div>
      <div>
        <img
          src="https://images.pexels.com/photos/8961006/pexels-photo-8961006.jpeg?auto=compress&cs=tinysrgb&w=1000"
          alt="Membru al echipei de foraj, cu echipament de protectie"
          width="1000"
          height="667"
          loading="lazy"
          class="aspect-[3/2] w-full rounded-xl object-cover shadow-md"
        />
      </div>
    </div>
  </section>

  <!-- Cifre -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="wrap">
      <h2 class="text-center text-3xl">Cifrele care ne reprezinta</h2>
      <div class="mt-10">
        <TrustBar />
      </div>
    </div>
  </section>

  <!-- Valori -->
  <section class="py-16 sm:py-20">
    <div class="wrap">
      <h2 class="text-3xl sm:text-4xl">Ce ne deosebeste</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          values.map((v) => (
            <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
              <div class="flex items-center gap-4">
                <IconTile icon={v.icon} />
                <h3 class="text-lg font-bold text-primary">{v.title}</h3>
              </div>
              <p class="mt-4 text-sm leading-relaxed text-muted">{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Garantii + Parteneri -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="wrap grid gap-10 lg:grid-cols-2">
      <div class="rounded-xl border border-border bg-background p-8">
        <div class="flex items-center gap-4">
          <IconTile icon="ph:seal-check-duotone" size="lg" />
          <h2 class="text-2xl">Garantie in scris</h2>
        </div>
        <p class="mt-4 leading-relaxed text-muted">
          Oferim pana la 5 ani garantie, mentionata clar in contract, in functie de tipul lucrarii.
          Iar dupa finalizare ramanem alaturi de tine cu suport si mentenanta.
        </p>
      </div>
      <div class="rounded-xl border border-border bg-background p-8">
        <div class="flex items-center gap-4">
          <IconTile icon="ph:medal-duotone" size="lg" />
          <h2 class="text-2xl">Marci de incredere</h2>
        </div>
        <p class="mt-4 leading-relaxed text-muted">
          Pentru sistemele de pompare lucram cu branduri recunoscute, pentru durabilitate si
          performanta in timp.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {
            partners.map((p) => (
              <span class="rounded-md border border-border bg-surface px-3 py-1.5 text-sm font-semibold text-primary">
                {p}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
