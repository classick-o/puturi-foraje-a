---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Button from '../../components/Button.astro';
import IconTile from '../../components/IconTile.astro';
import Faq from '../../components/Faq.astro';
import CtaBand from '../../components/CtaBand.astro';
import { site } from '../../lib/site';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((s) => ({ params: { slug: s.id }, props: { service: s } }));
}

const { service } = Astro.props;
const d = service.data;
const { Content } = await render(service);

const others = (await getCollection('services'))
  .sort((a, b) => a.data.order - b.data.order)
  .filter((s) => s.id !== service.id)
  .slice(0, 3);

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.title,
  description: d.excerpt,
  areaServed: 'RO',
  provider: { '@type': 'LocalBusiness', name: site.name },
};
const faqLd = d.faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: d.faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
// Breadcrumb doar pentru SEO (nu se afiseaza in UI)
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Acasa', item: new URL(withBase(''), Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Servicii', item: new URL(withBase('servicii'), Astro.site).href },
    { '@type': 'ListItem', position: 3, name: d.title },
  ],
};
const jsonLd = [serviceLd, breadcrumbLd, ...(faqLd ? [faqLd] : [])];
---

<BaseLayout
  title={d.seoTitle ?? d.title}
  description={d.seoDescription ?? d.excerpt}
  image={d.image}
  type="article"
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-primary text-white">
    <div
      class="pointer-events-none absolute inset-0 opacity-50"
      style="background-image: radial-gradient(60% 60% at 85% 0%, rgba(29,78,216,.4) 0, transparent 60%);"
    >
    </div>
    <div class="wrap relative grid items-center gap-10 py-14 lg:grid-cols-2 lg:py-20">
      <div>
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-[10px] bg-white/10 text-accent">
          <Icon name={d.icon} class="text-2xl" />
        </span>
        <h1 class="mt-4 text-3xl font-extrabold !text-white sm:text-4xl">{d.title}</h1>
        {d.heroSubtitle && <p class="mt-4 max-w-xl text-lg leading-relaxed text-white/75">{d.heroSubtitle}</p>}
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <Button href={withBase('contact')} variant="cta" icon="ph:paper-plane-tilt-fill">Cere oferta</Button>
          <Button href={site.phoneHref} variant="outline-light" icon="ph:phone-call-fill">{site.phone}</Button>
        </div>
      </div>
      {
        d.image && (
          <div>
            <img
              src={d.image}
              alt={d.title}
              width="1280"
              height="853"
              loading="eager"
              class="aspect-[3/2] w-full rounded-xl object-cover shadow-lg ring-1 ring-white/10"
            />
          </div>
        )
      }
    </div>
  </section>

  <!-- CONTENT -->
  <section class="py-14 sm:py-20">
    <div class="wrap grid gap-12 lg:grid-cols-[1.6fr_1fr]">
      <div>
        <div class="rte max-w-2xl">
          <Content />
        </div>

        {
          d.forWhom.length > 0 && (
            <div class="mt-10">
              <h2 class="text-xl">Pentru cine</h2>
              <ul class="mt-4 grid gap-3 sm:grid-cols-2">
                {d.forWhom.map((f) => (
                  <li class="flex items-start gap-2.5 rounded-md border border-border bg-surface px-4 py-3 text-sm text-ink/90">
                    <Icon name="ph:check-circle-duotone" class="mt-0.5 text-lg text-secondary" />
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        {
          d.benefits.length > 0 && (
            <div class="mt-12">
              <h2 class="text-xl">De ce sa ne alegi</h2>
              <div class="mt-5 grid gap-5 sm:grid-cols-2">
                {d.benefits.map((b) => (
                  <div class="rounded-xl border border-border bg-surface p-5 shadow-sm">
                    <div class="flex items-center gap-3">
                      <Icon name="ph:check-circle-duotone" class="shrink-0 text-2xl text-secondary" />
                      <h3 class="text-base font-bold text-primary">{b.title}</h3>
                    </div>
                    <p class="mt-2.5 text-sm leading-relaxed text-muted">{b.text}</p>
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </div>

      <!-- Sidebar -->
      <aside>
        <div class="lg:sticky lg:top-24">
          {
            d.specs.length > 0 && (
              <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
                <h3 class="font-bold text-primary">Detalii tehnice</h3>
                <dl class="mt-3 divide-y divide-border">
                  {d.specs.map((s) => (
                    <div class="flex justify-between gap-4 py-2.5 text-sm">
                      <dt class="shrink-0 text-muted">{s.label}</dt>
                      <dd class="text-right font-medium text-primary">{s.value}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )
          }
          <div class="mt-5 rounded-xl border border-secondary/20 bg-secondary-soft p-6">
            <h3 class="font-bold text-primary">Cere o oferta gratuita</h3>
            <p class="mt-1.5 text-sm text-ink/80">Iti raspundem rapid, cu un deviz clar si fara obligatii.</p>
            <div class="mt-4 flex flex-col gap-2">
              <Button href={withBase('contact')} variant="cta" class="w-full">Cere oferta</Button>
              <Button href={site.phoneHref} variant="outline" icon="ph:phone-call-fill" class="w-full">{site.phone}</Button>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  {
    d.faq.length > 0 && (
      <section class="bg-surface py-16 sm:py-20">
        <div class="wrap">
          <h2 class="text-center text-3xl">Intrebari frecvente</h2>
          <div class="mt-10">
            <Faq items={d.faq} />
          </div>
        </div>
      </section>
    )
  }

  <!-- ALTE SERVICII -->
  <section class="py-16 sm:py-20">
    <div class="wrap">
      <h2 class="text-2xl">Alte servicii</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          others.map((s) => (
            <a
              href={withBase(`servicii/${s.id}`)}
              class="group flex items-center gap-4 rounded-xl border border-border bg-surface p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:border-secondary/30 hover:shadow-md"
            >
              <IconTile icon={s.data.icon} />
              <span class="flex items-center gap-1 font-bold text-primary">
                {s.data.title}
                <Icon name="ph:arrow-right-bold" class="text-xs text-secondary transition-transform group-hover:translate-x-1" />
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
