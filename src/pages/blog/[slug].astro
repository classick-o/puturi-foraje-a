---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, render } from 'astro:content';
import { site } from '../../lib/site';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const d = post.data;
const { Content } = await render(post);
const fmt = (s: string) => s.split('-').reverse().join('.');

const others = (await getCollection('blog'))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => (a.data.date < b.data.date ? 1 : -1))
  .slice(0, 2);

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: d.title,
  description: d.excerpt,
  image: d.image,
  datePublished: d.date,
  author: { '@type': 'Organization', name: site.name },
  publisher: { '@type': 'Organization', name: site.name },
};
---

<BaseLayout
  title={d.seoTitle ?? d.title}
  description={d.seoDescription ?? d.excerpt}
  image={d.image}
  type="article"
  jsonLd={articleLd}
>
  <article>
    <header class="border-b border-border bg-surface">
      <div class="wrap py-12 sm:py-16">
        <nav class="mb-5 flex flex-wrap items-center gap-1.5 text-sm text-muted" aria-label="Breadcrumb">
          <a href={withBase('')} class="hover:text-secondary">Acasa</a>
          <span class="opacity-50">/</span>
          <a href={withBase('blog')} class="hover:text-secondary">Blog</a>
          <span class="opacity-50">/</span>
          <span class="text-primary">{d.category}</span>
        </nav>
        <div class="flex items-center gap-2 text-xs">
          <span class="font-semibold uppercase tracking-wide text-secondary">{d.category}</span>
          <span class="text-muted">{fmt(d.date)}</span>
        </div>
        <h1 class="mt-3 max-w-3xl text-3xl sm:text-4xl">{d.title}</h1>
      </div>
    </header>

    <div class="wrap py-12 sm:py-16">
      <div class="mx-auto max-w-3xl">
        <img
          src={d.image}
          alt={d.title}
          width="1280"
          height="720"
          loading="eager"
          class="aspect-[16/9] w-full rounded-xl object-cover shadow-md"
        />
        <div class="rte mt-10">
          <Content />
        </div>

        <div class="mt-10 rounded-xl border border-secondary/20 bg-secondary-soft p-6 text-center">
          <h2 class="text-xl text-primary">Ai nevoie de un put forat?</h2>
          <p class="mx-auto mt-2 max-w-md text-sm text-muted">Cere o oferta gratuita, fara obligatii. Iti raspundem rapid.</p>
          <a
            href={withBase('contact')}
            class="mt-4 inline-flex items-center gap-2 rounded-md bg-accent px-6 py-3 font-semibold text-primary shadow-md transition-colors hover:bg-accent-hover"
          >
            <Icon name="ph:paper-plane-tilt-fill" /> Cere oferta
          </a>
        </div>
      </div>
    </div>
  </article>

  {
    others.length > 0 && (
      <section class="bg-surface py-16">
        <div class="wrap">
          <h2 class="text-2xl">Mai citeste</h2>
          <div class="mt-8 grid gap-6 md:grid-cols-2">
            {others.map((p) => (
              <a
                href={withBase(`blog/${p.id}`)}
                class="group flex items-center gap-4 rounded-xl border border-border bg-background p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md"
              >
                <img
                  src={p.data.image}
                  alt={p.data.title}
                  width="160"
                  height="120"
                  loading="lazy"
                  class="h-20 w-28 shrink-0 rounded-md object-cover"
                />
                <span>
                  <span class="block text-xs font-semibold uppercase tracking-wide text-secondary">{p.data.category}</span>
                  <span class="mt-1 block font-bold leading-snug text-primary">{p.data.title}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
