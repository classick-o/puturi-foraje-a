---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/url';

const posts = (await getCollection('blog')).sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
const fmt = (s: string) => s.split('-').reverse().join('.');
---

<BaseLayout
  title="Blog - resurse despre foraje si puturi"
  description="Ghiduri si articole utile despre foraje puturi apa: costuri, legislatie, intretinere si sfaturi practice."
>
  <PageHero
    eyebrow="Blog"
    title="Resurse si ghiduri despre foraje"
    subtitle="Sfaturi practice despre costuri, legislatie si intretinerea puturilor, scrise pe intelesul tuturor."
    breadcrumb={[{ label: 'Acasa', href: withBase('') }, { label: 'Blog' }]}
  />

  <section class="py-16 sm:py-20">
    <div class="wrap">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <a
              href={withBase(`blog/${post.id}`)}
              class="group flex flex-col overflow-hidden rounded-xl border border-border bg-surface shadow-sm transition-all hover:-translate-y-1 hover:shadow-md"
            >
              <div class="aspect-[16/9] overflow-hidden">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  width="800"
                  height="450"
                  loading="lazy"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center gap-2 text-xs">
                  <span class="font-semibold uppercase tracking-wide text-secondary">{post.data.category}</span>
                  <span class="text-muted">{fmt(post.data.date)}</span>
                </div>
                <h2 class="mt-2 text-lg font-bold leading-snug text-primary">{post.data.title}</h2>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{post.data.excerpt}</p>
                <span class="mt-4 text-sm font-semibold text-secondary">Citeste articolul</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
