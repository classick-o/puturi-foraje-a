---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import { Icon } from 'astro-icon/components';
import { site } from '../lib/site';
import { withBase } from '../lib/url';

const contactCards = [
  { icon: 'ph:phone-call-duotone', label: 'Telefon', value: site.phone, href: site.phoneHref },
  { icon: 'ph:whatsapp-logo-duotone', label: 'WhatsApp', value: 'Scrie-ne pe WhatsApp', href: site.whatsapp },
  { icon: 'ph:envelope-simple-duotone', label: 'Email', value: site.email, href: `mailto:${site.email}` },
];
---

<BaseLayout
  title="Contact"
  description="Contacteaza-ne pentru o oferta gratuita la foraje puturi apa. Telefon, WhatsApp, email sau formular - iti raspundem rapid."
>
  <PageHero
    eyebrow="Contact"
    title="Hai sa vorbim despre proiectul tau"
    subtitle="Cere o oferta gratuita sau pune-ne orice intrebare. Iti raspundem in cel mai scurt timp."
    breadcrumb={[{ label: 'Acasa', href: withBase('') }, { label: 'Contact' }]}
  />

  <section class="py-16 sm:py-20">
    <div class="wrap grid gap-12 lg:grid-cols-[1.3fr_1fr]">
      <!-- Form -->
      <div>
        <h2 class="text-2xl">Cere o oferta</h2>
        <p class="mt-2 text-muted">Completeaza formularul, iar noi revenim cu un deviz personalizat.</p>
        <div class="mt-6">
          <ContactForm />
        </div>
      </div>

      <!-- Detalii -->
      <div>
        <h2 class="text-2xl">Date de contact</h2>
        <div class="mt-6 space-y-3">
          {
            contactCards.map((c) => (
              <a
                href={c.href}
                class="flex items-center gap-4 rounded-xl border border-border bg-surface p-4 shadow-sm transition-colors hover:border-secondary/30"
              >
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-[10px] bg-secondary-soft text-2xl text-secondary">
                  <Icon name={c.icon} />
                </span>
                <span>
                  <span class="block text-xs uppercase tracking-wide text-muted">{c.label}</span>
                  <span class="block font-bold text-primary">{c.value}</span>
                </span>
              </a>
            ))
          }
          <div class="flex items-center gap-4 rounded-xl border border-border bg-surface p-4 shadow-sm">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-[10px] bg-secondary-soft text-2xl text-secondary">
              <Icon name="ph:map-pin-duotone" />
            </span>
            <span>
              <span class="block text-xs uppercase tracking-wide text-muted">Adresa</span>
              <span class="block font-bold text-primary">{site.address}</span>
            </span>
          </div>
          <div class="flex items-center gap-4 rounded-xl border border-border bg-surface p-4 shadow-sm">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-[10px] bg-secondary-soft text-2xl text-secondary">
              <Icon name="ph:clock-duotone" />
            </span>
            <span>
              <span class="block text-xs uppercase tracking-wide text-muted">Program</span>
              <span class="block font-semibold text-primary">{site.schedule}</span>
            </span>
          </div>
        </div>

        <div class="mt-6 flex items-start gap-3 rounded-xl border border-secondary/20 bg-secondary-soft p-4 text-sm text-ink/80">
          <Icon name="ph:lightning-duotone" class="mt-0.5 shrink-0 text-xl text-secondary" />
          <p>Raspundem de regula in cateva ore in timpul programului. Pentru urgente, suna-ne direct.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Harta -->
  <section class="pb-16 sm:pb-20">
    <div class="wrap">
      <div class="overflow-hidden rounded-xl border border-border shadow-sm">
        <iframe
          title="Harta zona deservita"
          src="https://www.google.com/maps?q=Romania&z=6&output=embed"
          width="100%"
          height="380"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
