---
import '@fontsource-variable/plus-jakarta-sans';
import '../styles/global.css';
import { site } from '../lib/site';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingButtons from '../components/FloatingButtons.astro';
import Seo from '../components/Seo.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
}
const { title, description, image, type, noindex, jsonLd } = Astro.props;

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.name,
  description: site.description,
  telephone: site.phoneHref.replace('tel:', ''),
  email: site.email,
  url: Astro.site?.href,
  areaServed: 'RO',
  address: { '@type': 'PostalAddress', addressCountry: 'RO' },
  openingHours: 'Mo-Fr 08:00-18:00',
  priceRange: '$$',
};
const pageLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allLd = [orgLd, ...pageLd];
const faviconHref = import.meta.env.BASE_URL.replace(/\/+$/, '') + '/favicon.svg';
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <meta name="theme-color" content="#0B1F3B" />
    <meta name="generator" content={Astro.generator} />
    <Seo title={title} description={description} image={image} type={type} noindex={noindex} />
    {allLd.map((obj) => <script type="application/ld+json" set:html={JSON.stringify(obj)} />)}
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-white"
    >
      Sari la continut
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <FloatingButtons />
  </body>
</html>
